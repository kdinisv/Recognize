{
  "name": "recognize",
  "version": "3.1.6",
  "description": "Lightweight zero-dependency captcha solving client for RuCaptcha and Anti-Captcha (API v2)",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kdinisv/Recognize.git"
  },
  "keywords": [
    "captcha",
    "rucaptcha",
    "2captcha",
    "anti-captcha",
    "anticaptcha",
    "recaptcha",
    "hcaptcha",
    "turnstile",
    "funcaptcha",
    "geetest",
    "solver",
    "typescript"
  ],
  "author": "kdinisv",
  "license": "SEE LICENSE IN LICENSE",
  "sideEffects": false,
  "bugs": {
    "url": "https://github.com/kdinisv/Recognize/issues"
  },
  "homepage": "https://github.com/kdinisv/Recognize#readme",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  }
}
